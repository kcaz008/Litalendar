# Database (Neon, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/litalendar?sslmode=require"

# App URL (no trailing slash)
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app
APP_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 32+ char random string for signing session cookies
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
